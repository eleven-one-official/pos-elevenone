# Base URL of the Laravel API (the RestoPOS backend).
# The backend (artisan serve :8001, loopback-only) sits behind Caddy, which
# terminates TLS on :8443 for the whole LAN — tablets and this PC both use it.
# 192.168.1.166 is this PC's Wi-Fi IP (reserve it in the router; if it changes,
# update this URL and the Caddyfile in the project root).
VITE_API_URL=https://192.168.1.166:8443/api
